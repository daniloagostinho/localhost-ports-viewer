{
  "name": "localhost-ports-viewer",
  "displayName": "Localhost Ports Viewer",
  "publisher": "danilodevsilva",
  "description": "Monitor all localhost ports in real time. Detects Node, React, Next.js, databases and more — open, copy or kill any service directly from the VS Code sidebar.",
  "type": "module",
  "version": "0.0.24",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "localhost",
    "ports",
    "port viewer",
    "dev server",
    "process monitor",
    "network",
    "services",
    "debugging",
    "node",
    "development tools"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localhostPortsContainer",
          "title": "Localhost",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "localhostPortsContainer": [
        {
          "id": "localhostPorts",
          "name": "",
          "icon": "icon.png",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Localhost Ports Viewer",
      "properties": {
        "localhostPortsViewer.refreshInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Auto-refresh interval in milliseconds (minimum 1000ms)."
        },
        "localhostPortsViewer.commandTimeout": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for each OS command used to detect ports."
        },
        "localhostPortsViewer.debugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debug logs in the Output channel."
        },
        "localhostPortsViewer.openBrowserTarget": {
          "type": "string",
          "enum": ["external", "internal"],
          "enumDescriptions": [
            "Open in the system default browser",
            "Open in VS Code's Simple Browser"
          ],
          "default": "external",
          "description": "Where to open localhost URLs when clicking a port."
        }
      }
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniloagostinho/localhost-ports-viewer.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.50",
    "@types/tcp-port-used": "^1.0.4",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ps-list": "^8.1.1",
    "tcp-port-used": "^1.0.2"
  }
}
