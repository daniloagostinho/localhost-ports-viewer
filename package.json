{
  "name": "localhost-ports-viewer",
  "displayName": "Localhost Ports Viewer",
  "publisher": "daniloagostinho",
  "description": "Visualize e abra serviços rodando no localhost diretamente do VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:localhostPorts"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localhostPortsContainer",
          "title": "Localhost",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "localhostPortsContainer": [
        {
          "id": "localhostPorts",
          "name": "Localhost Ports"
        }
      ]
    },
    "commands": [
      {
        "command": "localhostPorts.refresh",
        "title": "Refresh Localhost Ports"
      },
      {
        "command": "localhostPorts.open",
        "title": "Open Port in Browser"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.50",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}
